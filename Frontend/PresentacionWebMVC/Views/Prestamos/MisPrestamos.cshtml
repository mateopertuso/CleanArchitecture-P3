@model PresentacionWebMVC.Models.PrestamosSocioViewModel

<h1>Mis Préstamos</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form method="post" class="mb-4">

    <div class="row">

        <div class="col-md-3">

            <label class="form-label">
                Mes
            </label>

            <input asp-for="Mes"
                   type="number"
                   min="1"
                   max="12"
                   class="form-control" />

        </div>

        <div class="col-md-3">

            <label class="form-label">
                Año
            </label>

            <input asp-for="Anio"
                   type="number"
                   class="form-control" />

        </div>

    </div>

    <br />

    <button type="submit"
            class="btn btn-primary">

        Buscar

    </button>

</form>

@if (Model.Prestamos.Any())
{
    <table class="table table-bordered">

        <thead>

            <tr>
                <th>ID</th>
                <th>Telescopio</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Estado</th>
                <th>Situación</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var p in Model.Prestamos)
            {
                <tr>

                    <td>@p.Id</td>

                    <td>@p.Telescopio</td>

                    <td>
                        @p.FechaInicio.ToShortDateString()
                    </td>

                    <td>
                        @p.FechaFin.ToShortDateString()
                    </td>

                    <td>@p.Estado</td>

                    <td>

                        @if (p.Atrasado)
                        {
                            <span class="text-danger fw-bold">
                                ATRASADO
                            </span>
                        }
                        else
                        {
                            <span class="text-success fw-bold">
                                AL DÍA
                            </span>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>
}
else
{
    <div class="alert alert-info">
        No existen préstamos para el período seleccionado.
    </div>
}