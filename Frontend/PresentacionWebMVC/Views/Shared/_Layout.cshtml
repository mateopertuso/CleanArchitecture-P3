@{
    string rol = Context.Session.GetString("rol");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] StellarMinds</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PresentacionWebMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Stellar Minds</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (rol == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Usuarios" asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }
                        @if (rol == "ADMINISTRADOR")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Usuarios" asp-action="Create">
                                    Alta Usuario
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Equipos" asp-action="Index">
                                    Equipos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Prestamos"
                                   asp-action="SociosPorTelescopio">
                                    Socios por Telescopio
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamos" asp-action="AuditoriasPrestamos">
                                    Auditoria de préstamos
                                </a>
                            </li>

                        }
                        @if (rol == "COORDINADOR")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Prestamos"
                                   asp-action="Create">
                                    Crear Préstamo
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Prestamos"
                                   asp-action="Devolver">
                                    Devolver Préstamo
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Prestamos"
                                   asp-action="SociosPorTelescopio">
                                    Socios por Telescopio
                                </a>
                            </li>
                        }
                            @if (rol == "SOCIO")
                            {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Observaciones"
                                   asp-action="Create">
                                    Crear Observación
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Prestamos"
                                   asp-action="MisPrestamos">
                                    Mis Préstamos
                                </a>
                            </li>
                            }
                        @if (rol != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Observaciones"
                                   asp-action="Ranking">
                                    Ranking Objetos Celestes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Usuarios" asp-action="Logout">Logout</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PresentacionWebMVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
