@model PresentacionWebMVC.Models.DTOs.OcularDTO

<h1>Editar Ocular</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="EditOcular"
      method="post">

    <input type="hidden"
           asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">
            Marca
        </label>

        <input asp-for="Marca"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            Modelo
        </label>

        <input asp-for="Modelo"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            Cantidad Disponible
        </label>

        <input asp-for="CantidadDisponible"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            Diámetro Mm
        </label>

        <input asp-for="DiametroMm"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">
            Campo Visual Grados
        </label>

        <input asp-for="CampoVisualGrados"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-warning">
        Guardar cambios
    </button>

</form>